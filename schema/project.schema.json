{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CanvasVideo Project",
  "type": "object",
  "required": ["name", "components"],
  "properties": {
    "name": {
      "type": "string",
      "description": "项目名称"
    },
    "theme": {
      "type": "string",
      "description": "主题名称：仅支持 white（白色清爽商务风）和 black（深色科技沉浸风），不支持自定义",
      "enum": ["white", "black"]
    },
    "duration": {
      "type": "number",
      "minimum": 0,
      "description": "视频总时长（秒）"
    },
    "audio": {
      "type": "string",
      "description": "音频文件路径"
    },
    "cover": {
      "type": "string",
      "description": "封面图路径"
    },
    "viewport": {
      "type": "object",
      "properties": {
        "width": { "type": "number" },
        "height": { "type": "number" }
      },
      "required": ["width", "height"]
    },
    "canvas": {
      "type": "object",
      "properties": {
        "width": { "type": "number" },
        "height": { "type": "number" }
      },
      "required": ["width", "height"]
    },
    "subtitles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["start", "end", "text"],
        "properties": {
          "start": { "type": "number" },
          "end": { "type": "number" },
          "text": { "type": "string" },
          "asset": { "type": "string" }
        }
      }
    },
    "chapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "start", "end"],
        "properties": {
          "name": { "type": "string" },
          "start": { "type": "number" },
          "end": { "type": "number" }
        }
      }
    },
    "regions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "x", "y"],
        "properties": {
          "name": { "type": "string" },
          "x": { "type": "number" },
          "y": { "type": "number" }
        }
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "position"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "content": { "type": "string" },
          "asset": { "type": "string" },
          "position": {
            "type": "object",
            "required": ["x", "y", "w", "h"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "w": { "type": "number" },
              "h": { "type": "number" }
            }
          },
          "start": { "type": "number" },
          "end": { "type": "number" },
          "segments": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["start", "end"],
              "properties": {
                "start": { "type": "number" },
                "end": { "type": "number" }
              }
            }
          },
          "children": {
            "type": "array",
            "items": { "$ref": "#/properties/components/items" }
          }
        }
      }
    },
    "settings": {
      "type": "object",
      "properties": {
        "autoPlay": { "type": "boolean" },
        "loop": { "type": "boolean" },
        "minScale": { "type": "number" },
        "maxScale": { "type": "number" },
        "ease": { "type": "number" },
        "contentZoomRatio": {
          "type": "number",
          "minimum": 0.85,
          "maximum": 0.95,
          "default": 0.9,
          "description": "视频播放区域内容缩放比例，推荐 0.9（区间 0.85-0.95）"
        },
        "preFullViewDuration": {
          "type": "number",
          "minimum": 0,
          "maximum": 0.6,
          "default": 0.4,
          "description": "视频开始前的全景预览时长（秒），推荐 0.4，最大 0.6"
        },
        "postFullViewDuration": {
          "type": "number",
          "minimum": 0,
          "maximum": 0.6,
          "default": 0.4,
          "description": "视频结束后的全景回收时长（秒），推荐 0.4，最大 0.6"
        }
      }
    }
  },
  "dependencies": {
    "subtitles": {
      "description": "subtitles 字段必须与 audio 字段共存：有 subtitles 必须有 audio",
      "required": ["audio"]
    }
  }
}
