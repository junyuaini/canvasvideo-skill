{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://canvasvideo.skill/project.schema.json",
  "title": "CanvasVideo Project",
  "description": "CanvasVideo 视频项目 project.json 的统一规范，被 skill scripts/validate.js 与 server projectValidator.js 共同使用。",
  "type": "object",
  "required": ["name", "components"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "项目名称"
    },
    "description": {
      "type": "string",
      "description": "项目描述"
    },
    "theme": {
      "type": "string",
      "enum": ["white", "black"],
      "description": "主题名称：仅支持 white（白色清爽商务风）和 black（深色科技沉浸风），不支持自定义"
    },
    "duration": {
      "type": "number",
      "minimum": 0,
      "description": "视频总时长（秒）"
    },
    "audio": {
      "description": "音频配置。字符串=旧写法（向后兼容）；对象=推荐写法",
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "description": "音频文件路径（旧写法）"
        },
        {
          "type": "object",
          "description": "音频配置对象（推荐）",
          "required": ["path"],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1,
              "description": "音频文件路径"
            },
            "loop": {
              "type": "boolean",
              "default": false,
              "description": "是否循环播放。BGM 用法建议 true，配音用法保持 false"
            },
            "fadeIn": {
              "type": "number",
              "minimum": 0,
              "maximum": 5,
              "default": 0,
              "description": "淡入秒数（0-5）。BGM 用法建议 1"
            },
            "fadeOut": {
              "type": "number",
              "minimum": 0,
              "maximum": 5,
              "default": 0,
              "description": "淡出秒数（0-5）。BGM 用法建议 2"
            }
          }
        }
      ]
    },
    "cover": {
      "type": "string",
      "description": "封面图路径"
    },
    "viewport": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "number", "minimum": 1 },
        "height": { "type": "number", "minimum": 1 }
      },
      "description": "视频播放区域尺寸（用户实际看到的视频窗口）"
    },
    "canvas": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "number", "minimum": 1 },
        "height": { "type": "number", "minimum": 1 }
      },
      "description": "画布尺寸（容纳所有区域的总画布）"
    },
    "subtitles": {
      "type": "array",
      "description": "字幕数组。subtitles 必须与 audio 共生（依赖见 dependencies）",
      "items": {
        "type": "object",
        "required": ["start", "end", "text"],
        "properties": {
          "start": { "type": "number", "minimum": 0 },
          "end": { "type": "number", "minimum": 0 },
          "text": { "type": "string", "minLength": 1 },
          "asset": { "type": "string" }
        }
      }
    },
    "chapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "start", "end"],
        "properties": {
          "name": { "type": "string" },
          "start": { "type": "number", "minimum": 0 },
          "end": { "type": "number", "minimum": 0 }
        }
      }
    },
    "regions": {
      "type": "array",
      "description": "区域定义。每个区域是视口大小的逻辑分块",
      "items": {
        "type": "object",
        "required": ["name", "x", "y"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "x": { "type": "number" },
          "y": { "type": "number" }
        }
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "description": "组件列表。至少 1 个组件",
      "items": { "$ref": "#/definitions/component" }
    },
    "settings": {
      "type": "object",
      "properties": {
        "autoPlay": { "type": "boolean" },
        "loop": { "type": "boolean" },
        "minScale": { "type": "number" },
        "maxScale": { "type": "number" },
        "ease": { "type": "number" },
        "contentZoomRatio": {
          "type": "number",
          "minimum": 0.85,
          "maximum": 0.95,
          "default": 0.9,
          "description": "视频播放区域内容缩放比例，推荐 0.9（区间 0.85-0.95）"
        },
        "preFullViewDuration": {
          "type": "number",
          "minimum": 0,
          "maximum": 0.6,
          "default": 0.4,
          "description": "视频开始前的全景预览时长（秒），推荐 0.4，最大 0.6"
        },
        "postFullViewDuration": {
          "type": "number",
          "minimum": 0,
          "maximum": 0.6,
          "default": 0.4,
          "description": "视频结束后的全景回收时长（秒），推荐 0.4，最大 0.6"
        }
      }
    }
  },
  "dependencies": {
    "subtitles": {
      "description": "subtitles 字段必须与 audio 字段共存：有 subtitles 必须有 audio",
      "required": ["audio"]
    }
  },
  "definitions": {
    "component": {
      "type": "object",
      "required": ["id", "type", "position"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_\\-]+$",
          "description": "组件 ID。推荐格式 P{区域}-{编号}，如 P1-001"
        },
        "type": {
          "type": "string",
          "enum": [
            "TitleComponent",
            "TextComponent",
            "ImageComponent",
            "CardComponent",
            "QuoteComponent",
            "BadgeComponent",
            "CornerComponent",
            "ShockComponent",
            "GraphicComponent",
            "AggregateComponent"
          ],
          "description": "组件类型，10 个内置组件之一"
        },
        "position": {
          "type": "object",
          "required": ["x", "y", "w", "h"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "w": { "type": "number", "minimum": 1 },
            "h": { "type": "number", "minimum": 1 }
          }
        },
        "fullRow": {
          "type": "boolean",
          "default": false,
          "description": "是否独占整行（标题等）"
        },
        "content": {
          "type": "object",
          "description": "组件内容字段。具体结构按 type 不同，详见 /api/component/spec"
        },
        "customStyle": {
          "type": "object",
          "description": "组件自定义样式。字段按 type/variant 不同，详见 /api/component/spec"
        },
        "asset": { "type": "string" },
        "start": { "type": "number", "minimum": 0 },
        "end": { "type": "number", "minimum": 0 },
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["start", "end"],
            "properties": {
              "start": { "type": "number", "minimum": 0 },
              "end": { "type": "number", "minimum": 0 }
            }
          }
        },
        "layout": {
          "type": "string",
          "description": "AggregateComponent layout 模式：关联 layouts.json 模板键"
        },
        "useExternalPosition": {
          "type": "boolean",
          "description": "AggregateComponent layout 模式下是否使用外部 position 覆盖模板尺寸"
        },
        "slot": {
          "type": "string",
          "description": "子组件在 AggregateComponent layout 模式下的插槽名"
        },
        "children": {
          "type": "array",
          "description": "子组件，主要给 AggregateComponent 使用",
          "items": { "$ref": "#/definitions/component" }
        }
      }
    }
  }
}
