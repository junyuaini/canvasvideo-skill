  "subtitles": [
    {
      "start": 0,
      "end": 1.533,
      "text": "都说AI会取代程序员"
    },
    {
      "start": 1.533,
      "end": 3.633,
      "text": "我4小时帮老板做了个会员管理系统"
    },
    {
      "start": 3.633,
      "end": 5.033,
      "text": "小区理发的时候"
    },
    {
      "start": 5.033,
      "end": 6.3,
      "text": "老板说会员系统要到期"
    },
    {
      "start": 6.3,
      "end": 7.833,
      "text": "准备续费 每年大几百"
    },
    {
      "start": 7.833,
      "end": 8.833,
      "text": "就存个会员信息"
    },
    {
      "start": 8.833,
      "end": 10.966,
      "text": "我当场承诺 给他免费做一个"
    },
    {
      "start": 10.966,
      "end": 13.766,
      "text": "前两天发给他了 今天来说说咋做的"
    },
    {
      "start": 13.766,
      "end": 15.166,
      "text": "直接跟AI口述需求"
    },
    {
      "start": 15.166,
      "end": 16.433,
      "text": "会员办卡消费扣减"
    },
    {
      "start": 16.433,
      "end": 17.233,
      "text": "记录查询"
    },
    {
      "start": 17.233,
      "end": 18.466,
      "text": "AI自己理解重点"
    },
    {
      "start": 18.466,
      "end": 20,
      "text": "还搜了网上的最佳实践"
    },
    {
      "start": 20,
      "end": 21.2,
      "text": "2分钟就出需求文档"
    },
    {
      "start": 21.2,
      "end": 24.466,
      "text": "我确认后 10分钟AI出设计文档"
    },
    {
      "start": 24.466,
      "end": 27.066,
      "text": "这个最关键 没有它 后面全是黑盒"
    },
    {
      "start": 27.066,
      "end": 28.8,
      "text": "然后AI按设计文档落地代码"
    },
    {
      "start": 28.8,
      "end": 30.3,
      "text": "简单系统20分钟出第一版"
    },
    {
      "start": 30.3,
      "end": 31.4,
      "text": "我自己写起码好几天"
    },
    {
      "start": 31.4,
      "end": 32.633,
      "text": "第二个关键点来了"
    },
    {
      "start": 32.633,
      "end": 34.766,
      "text": "要让AI按照代码检查清单自查一遍"
    },
    {
      "start": 34.766,
      "end": 35.733,
      "text": "并输出检查结果"
    },
    {
      "start": 35.733,
      "end": 38.466,
      "text": "第三个关键点 让AI输出一份测试案例"
    },
    {
      "start": 38.466,
      "end": 40.8,
      "text": "最后才是调试优化 部署上线"
    },
    {
      "start": 40.8,
      "end": 43.133,
      "text": "前后花了4小时 老板打开就能用"
    },
    {
      "start": 43.133,
      "end": 44.633,
      "text": "直接给他省了大几百块"
    },
    {
      "start": 44.633,
      "end": 46.766,
      "text": "要我说 AI不会取代程序员"
    },
    {
      "start": 46.766,
      "end": 47.7,
      "text": "会用AI的程序员"
    },
    {
      "start": 47.7,
      "end": 48.866,
      "text": "反而可能会有更多机会"
    },
    {
      "start": 48.866,
      "end": 51.333,
      "text": "评论区留个言 我把AI专用设计文档"
    },
    {
      "start": 51.333,
      "end": 52.966,
      "text": "自查清单案例模板发你"
    }
  ],
